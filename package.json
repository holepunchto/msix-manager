{
  "name": "msix-manager",
  "version": "0.2.0",
  "description": "Install and update MSIX packages from JavaScript",
  "exports": {
    "./package": "./package.json",
    ".": {
      "bare": {
        "win32": "./index.js",
        "default": "./unsupported.js"
      },
      "default": "./index.js"
    }
  },
  "imports": {
    "#binding": {
      "bare": "./lib/binding/bare.js",
      "node": "./lib/binding/node.js"
    },
    "events": {
      "bare": "bare-events",
      "default": "events"
    },
    "url": {
      "bare": "bare-url",
      "default": "url"
    }
  },
  "files": [
    "index.js",
    "unsupported.js",
    "binding.cc",
    "CMakeLists.txt",
    "lib",
    "prebuilds"
  ],
  "addon": true,
  "scripts": {
    "format": "prettier --write .",
    "lint": "prettier --check . && lunte",
    "test": "npm run test:node && npm run test:bare",
    "test:bare": "brittle-bare --coverage test.js",
    "test:node": "brittle-node --coverage test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/msix-manager.git"
  },
  "author": "Holepunch",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/msix-manager/issues"
  },
  "homepage": "https://github.com/holepunchto/msix-manager#readme",
  "dependencies": {
    "bare-events": "^2.8.2",
    "bare-url": "^2.3.2",
    "require-addon": "^1.2.0"
  },
  "devDependencies": {
    "bare-compat-napi": "^1.3.9",
    "brittle": "^3.18.0",
    "cmake-bare": "^1.6.5",
    "cmake-napi": "^1.2.2",
    "cmake-npm": "^1.1.0",
    "lunte": "^1.6.0",
    "prettier": "^3.4.1",
    "prettier-config-holepunch": "^2.0.0"
  }
}
